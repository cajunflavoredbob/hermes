# --- Required -----------------------------------------------------------
TELEGRAM_BOT_TOKEN=replace-with-bot-token-from-botfather
SEERR_URL=http://seerr-host:5056
SEERR_API_KEY=replace-with-seerr-api-key
# Your Telegram numeric user ID. Get it by DMing @userinfobot on Telegram.
ADMIN_TELEGRAM_ID=replace-with-your-telegram-user-id

# --- Optional: auto-fix for movies (Radarr) -----------------------------
RADARR_URL=
RADARR_API_KEY=

# --- Optional: auto-fix for TV (Sonarr) ---------------------------------
SONARR_URL=
SONARR_API_KEY=

# --- Optional: auto-fix allowlist ---------------------------------------
# Comma-separated Telegram user IDs allowed to use auto-fix.
# If unset, defaults to admin only.
# Anyone NOT on this list can still report issues but won't be offered auto-fix.
ALLOWED_AUTOFIX_TELEGRAM_IDS=
