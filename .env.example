# --- Required -----------------------------------------------------------
TELEGRAM_BOT_TOKEN=replace-with-bot-token-from-botfather
SEERR_URL=http://seerr-host:5056
SEERR_API_KEY=replace-with-seerr-api-key
# Your Telegram numeric user ID. Get it by DMing @userinfobot on Telegram.
ADMIN_TELEGRAM_ID=replace-with-your-telegram-user-id

# --- Optional: auto-fix for movies (Radarr) -----------------------------
RADARR_URL=
RADARR_API_KEY=

# --- Optional: auto-fix for TV (Sonarr) ---------------------------------
SONARR_URL=
SONARR_API_KEY=

# --- Optional: auto-fix allowlist ---------------------------------------
# Comma-separated Telegram user IDs allowed to use auto-fix.
# If unset, defaults to admin only.
# Anyone NOT on this list can still report issues but won't be offered auto-fix.
ALLOWED_AUTOFIX_TELEGRAM_IDS=

# --- Optional: encryption key for stored Plex tokens --------------------
# Fernet key used to encrypt Plex tokens at rest in the SQLite DB.
# If unset, Hermes generates one on first run and persists to /data/encryption.key.
# Generate manually with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
HERMES_ENCRYPTION_KEY=

# --- Optional: webhook secret -------------------------------------------
# Shared secret used in the Authorization header from Seerr's webhook config.
# If unset, Hermes auto-generates one on first run and persists to settings.json.
# Copy the auto-generated value from /admin (Webhook tab) into Seerr's webhook
# Authorization field, or set it explicitly here.
HERMES_WEBHOOK_SECRET=
